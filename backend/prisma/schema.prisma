// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(uuid())
  name             String
  email            String         @unique
  password_hash    String
  bio              String?
  trust_score      Float          @default(0.0)
  avatar           String?
  role             Role           @default(USER)
  created_at       DateTime       @default(now())
  
  skills           Skill[]
  sent_requests    SwapRequest[]  @relation("SenderRequests")
  received_requests SwapRequest[] @relation("ReceiverRequests")
  reviews_given    Review[]       @relation("Reviewer")
  reviews_received Review[]       @relation("Reviewed")
  notifications    Notification[]
}

enum Role {
  USER
  ADMIN
}

model Skill {
  id              String        @id @default(uuid())
  user_id         String
  user            User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  title           String
  description     String
  category        String
  level           SkillLevel    @default(BEGINNER)
  availability    String?
  created_at      DateTime      @default(now())

  offered_in      SwapRequest[] @relation("OfferedSkill")
  requested_in    SwapRequest[] @relation("RequestedSkill")
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Match {
  id                  String      @id @default(uuid())
  userA_id            String
  userB_id            String
  compatibility_score Float
  status              MatchStatus @default(PENDING)
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model SwapRequest {
  id                 String    @id @default(uuid())
  sender_id          String
  sender             User      @relation("SenderRequests", fields: [sender_id], references: [id])
  receiver_id        String
  receiver           User      @relation("ReceiverRequests", fields: [receiver_id], references: [id])
  offered_skill_id   String
  offered_skill      Skill     @relation("OfferedSkill", fields: [offered_skill_id], references: [id])
  requested_skill_id String
  requested_skill    Skill     @relation("RequestedSkill", fields: [requested_skill_id], references: [id])
  status             SwapStatus @default(PENDING)
  created_at         DateTime  @default(now())

  sessions           Session[]
}

enum SwapStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

model Message {
  id         String   @id @default(uuid())
  thread_id  String
  sender_id  String
  message    String
  sent_at    DateTime @default(now())
}

model Review {
  id          String   @id @default(uuid())
  reviewer_id String
  reviewer    User     @relation("Reviewer", fields: [reviewer_id], references: [id])
  reviewed_id String
  reviewed    User     @relation("Reviewed", fields: [reviewed_id], references: [id])
  rating      Int
  feedback    String?
  created_at  DateTime @default(now())
}

model Notification {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  type        String
  read_status Boolean  @default(false)
  created_at  DateTime @default(now())
}

model Session {
  id           String      @id @default(uuid())
  swap_id      String
  swap         SwapRequest @relation(fields: [swap_id], references: [id])
  datetime     DateTime
  status       String      @default("SCHEDULED")
  meeting_link String?
}
